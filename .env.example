# Environment Variables for ObsidianUI AI Component Generator

# Google Gemini API Key (required for Gemini Flash/Pro models)
GEMINI_API_KEY=

# OpenAI API Key (required for GPT-4o-mini and fine-tuned models)
OPENAI_API_KEY=

# Fine-tuned OpenAI Model ID (optional, falls back to gpt-4o-mini if not set)
# Example: ft:gpt-4o-mini-2024-07-18:your-org::your-model-id
OPENAI_FINETUNED_MODEL=
